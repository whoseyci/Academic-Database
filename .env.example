# Academic-Database local dev settings
RH_BRANCH=main
RH_REVIEW_HOST=127.0.0.1
RH_REVIEW_PORT=8765
RH_PULL_INTERVAL=30

# Install parser dependencies during one-click setup.
# 1 = install requirements-parser.txt, 0 = skip parser deps and only run core harness.
PDF2MD_INSTALL_PARSER=0

# Vision deps can be heavier; keep off by default.
PDF2MD_INSTALL_VISION=0

# Set to 1 to skip all pip setup from the Electron launcher after you have a working .venv.
ACADEMIC_DB_SKIP_PIP=0
